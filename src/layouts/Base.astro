---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'On-device AI chief of staff for macOS. Private meeting recording, transcription, and structured intelligence — all on your Mac.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <title>{title}</title>

    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://oschief.ai/images/og-image.png" />
    <meta property="og:url" content="https://oschief.ai" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://oschief.ai/images/og-image.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif&display=swap" rel="stylesheet" />
    <link rel="preload" href="/fonts/Geist-Variable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Dark-first: default is dark, toggle adds .light -->
    <script is:inline>
      const t = localStorage.getItem('theme');
      if (t === 'light') document.documentElement.classList.add('light');
    </script>
  </head>
  <body class="min-h-screen overflow-x-hidden">
    <slot />
    <Analytics />

    <script is:inline>
      // Scroll-driven animations with staggered children
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (!e.isIntersecting) return;
          const el = e.target;
          const anim = el.dataset.animate || 'fade-up';
          const delay = el.dataset.delay || '0';

          el.style.animationDelay = delay + 'ms';
          el.classList.add('animate-' + anim);
          el.style.opacity = '1';
          obs.unobserve(el);

          // Stagger children with [data-stagger]
          el.querySelectorAll('[data-stagger]').forEach((child, i) => {
            child.style.opacity = '0';
            child.style.animationDelay = (parseInt(delay) + (i + 1) * 100) + 'ms';
            child.classList.add('animate-' + (child.dataset.stagger || 'fade-up'));
            // Force reflow then reveal
            requestAnimationFrame(() => { child.style.opacity = '1'; });
          });
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('[data-animate]').forEach(el => {
        el.style.opacity = '0';
        obs.observe(el);
      });
    </script>
  </body>
</html>
