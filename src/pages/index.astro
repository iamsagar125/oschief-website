---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import AppPreview from '../components/AppPreview.astro';
import StorySection from '../components/StorySection.astro';
import PrivacyCallout from '../components/PrivacyCallout.astro';
import Features from '../components/Features.astro';
import Pricing from '../components/Pricing.astro';
import Testimonials from '../components/Testimonials.astro';
import WaitlistCTA from '../components/WaitlistCTA.astro';
import Footer from '../components/Footer.astro';
---

<Base title="OSChief — Every commitment tracked. Every promise kept.">
  <Nav />
  <main>
    <Hero />
    <AppPreview />

    <StorySection
      label="Capture"
      title="Every promise, caught"
      description="OSChief records your meetings and extracts the commitments — who promised what, to whom, by when. Not another transcript dump. The signal, not the noise."
      items={[
        'On-device transcription via MLX Whisper',
        'Commitments extracted automatically with owners',
        'Speaker diarization — You vs Others',
        'Works with Zoom, Meet, Teams, any app',
      ]}
      mockup="recording"
    />

    <StorySection
      label="Extract"
      title="Decisions, not summaries"
      description="Every meeting becomes a structured record: decisions with context, commitments with deadlines, open questions that need answers. The stuff that actually matters."
      items={[
        'Decisions extracted with full context',
        'Action items with owners and due dates',
        'Open questions flagged for follow-up',
        'Custom templates for your workflow',
      ]}
      mockup="summary"
      reverse
    />

    <StorySection
      label="Follow through"
      title="Nothing falls through"
      description="Each morning, OSChief tells you what you owe, what's owed to you, and what's slipping. Risk scoring flags commitments before they break. The loop closes."
      items={[
        'Morning brief: your commitments + calendar',
        'Risk scoring: green, amber, red',
        'Stale decision detection after 14 days',
        'Weekly intelligence digest',
      ]}
      mockup="morning"
    />

    <PrivacyCallout />
    <Features />
    <Pricing />
    <Testimonials />
    <WaitlistCTA />
  </main>
  <Footer />
</Base>
