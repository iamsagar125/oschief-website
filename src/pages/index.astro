---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import ProblemStatement from '../components/ProblemStatement.astro';
import FeaturePillars from '../components/FeaturePillars.astro';
import Features from '../components/Features.astro';
import Pricing from '../components/Pricing.astro';
import PrivacyCallout from '../components/PrivacyCallout.astro';
import WaitlistCTA from '../components/WaitlistCTA.astro';
import Footer from '../components/Footer.astro';
---

<Base title="OSChief — On-device chief of staff for macOS">
  <div id="top"></div>
  <Nav />
  <main>
    <Hero />
    <ProblemStatement />
    <FeaturePillars />
    <Features />
    <Pricing />
    <PrivacyCallout />
    <WaitlistCTA />
  </main>
  <Footer />
