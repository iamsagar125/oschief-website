---
const features = [
  {
    title: 'Meeting Intelligence',
    items: ['Live speaker-labeled transcription', 'Structured AI summaries', 'Role-based coaching for 10+ roles', 'Talk-time metrics & filler detection'],
  },
  {
    title: 'Proactive Intelligence',
    items: ['Daily morning brief', 'Commitment risk scoring', 'Stale decision alerts', 'Weekly intelligence digest'],
  },
  {
    title: 'People & Projects',
    items: ['Auto-built relationship graph', 'Per-person commitment tracking', 'Project grouping & timelines', 'Full decision lifecycle'],
  },
  {
    title: 'Integrations',
    items: ['Google Calendar + Microsoft 365', 'Obsidian vault export', 'Jira, Slack, Teams', 'Gmail for meeting prep'],
  },
];
---

<section id="features" class="py-20 md:py-28 px-6" data-animate>
  <div class="max-w-[1100px] mx-auto">
    <p class="text-[11px] font-medium uppercase tracking-[0.15em] text-primary mb-4 text-center">Everything you get</p>
    <h2 class="font-display text-[32px] md:text-[44px] leading-[1.08] text-foreground mb-14 text-center">
      Not another meeting recorder
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {features.map((f) => (
        <div class="border border-border rounded-md p-6 bg-card/50 hover:bg-card transition-colors">
          <h3 class="font-sans font-semibold text-[15px] text-foreground mb-4">{f.title}</h3>
          <ul class="space-y-2.5">
            {f.items.map((item) => (
              <li class="flex items-start gap-2.5 text-[13px] text-muted-foreground">
                <svg class="w-3.5 h-3.5 text-green mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
