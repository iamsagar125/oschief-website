<section class="pt-28 pb-16 md:pt-36 md:pb-24">
  <div class="max-w-content mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-12 items-center">
      <!-- Text (left-aligned, not centered) -->
      <div class="md:col-span-7">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-secondary text-[11px] font-medium text-muted-foreground mb-5">
          <span class="w-1.5 h-1.5 rounded-full bg-amber" aria-hidden="true"></span>
          Releasing soon — join the waitlist
        </div>

        <h1 class="font-display text-[40px] md:text-[52px] leading-[1.08] text-foreground mb-5">
          Your on-device<br/>chief of staff
        </h1>

        <p class="text-[17px] leading-relaxed text-muted-foreground max-w-[520px] mb-8">
          OSChief captures your meetings, structures every decision and commitment, and tells you each morning what matters. Local AI by default — no API keys, no cloud, no cost to get started.
        </p>

        <!-- Email capture -->
        <form id="waitlist-form" class="flex flex-col sm:flex-row gap-3 max-w-[440px]">
          <input
            type="email"
            name="email"
            required
            placeholder="you@company.com"
            class="flex-1 h-10 px-3.5 text-[13.5px] bg-card border border-border rounded-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-primary transition-colors"
          />
          <button
            type="submit"
            class="h-10 px-5 text-[13px] font-medium bg-primary text-primary-foreground rounded-sm hover:opacity-90 transition-opacity whitespace-nowrap"
          >
            Join waitlist
          </button>
        </form>

        <div id="waitlist-success" class="hidden mt-3 text-[13px] text-green">
          You're on the list. We'll let you know when OSChief is ready.
        </div>
        <div id="waitlist-error" class="hidden mt-3 text-[13px] text-red-500">
          Something went wrong. Please try again.
        </div>

        <p class="mt-4 text-[11px] text-muted-foreground">
          macOS only. Apple Silicon (M1+). No spam, ever.
        </p>
      </div>

      <!-- App preview (right) -->
      <div class="md:col-span-5">
        <div class="rounded-md border border-border bg-card p-3" style="box-shadow: var(--card-shadow);">
          <div class="rounded-sm bg-muted aspect-[4/3] flex items-center justify-center">
            <div class="text-center px-6">
              <div class="w-12 h-12 mx-auto mb-3 rounded-md overflow-hidden">
                <img src="/images/app-icon.png" alt="OSChief" width="48" height="48" />
              </div>
              <p class="text-[13px] font-medium text-foreground mb-1">OSChief for Mac</p>
              <p class="text-[11px] text-muted-foreground">Meeting intelligence that closes the loop</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const form = document.getElementById('waitlist-form');
  const success = document.getElementById('waitlist-success');
  const error = document.getElementById('waitlist-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    success?.classList.add('hidden');
    error?.classList.add('hidden');

    const email = new FormData(form).get('email');
    try {
      const res = await fetch('/api/subscribe.php', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      if (res.ok) {
        success?.classList.remove('hidden');
        form.reset();
      } else {
        const data = await res.json().catch(() => ({}));
        if (data.error === 'already_subscribed') {
          success?.classList.remove('hidden');
          success.textContent = "You're already on the list!";
        } else {
          error?.classList.remove('hidden');
        }
      }
    } catch {
      error?.classList.remove('hidden');
    }
  });
</script>
