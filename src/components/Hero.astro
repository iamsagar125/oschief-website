<section class="gradient-hero min-h-screen flex flex-col items-center justify-center px-6 relative">
  <div class="text-center max-w-[720px] mx-auto">
    <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-border bg-card/50 text-[12px] font-medium text-muted-foreground mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-amber" style="animation: pulse-glow 2s ease-in-out infinite;" aria-hidden="true"></span>
      Releasing soon
    </div>

    <h1 class="font-display text-[48px] md:text-[72px] leading-[1.05] text-foreground mb-6">
      Your on-device<br/>chief of staff
    </h1>

    <p class="text-[17px] md:text-[19px] leading-relaxed text-muted-foreground max-w-[520px] mx-auto mb-10">
      Captures your meetings, structures every decision, and tells you each morning what matters. Local AI — no cloud, no cost.
    </p>

    <form id="waitlist-form" class="flex flex-col sm:flex-row gap-3 max-w-[420px] mx-auto">
      <input
        type="email"
        name="email"
        required
        placeholder="you@company.com"
        class="flex-1 h-12 px-4 text-[16px] bg-card border border-border rounded-md text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors"
      />
      <button
        type="submit"
        class="h-12 px-6 text-[14px] font-semibold bg-primary text-primary-foreground rounded-md hover:opacity-90 transition-opacity whitespace-nowrap"
      >
        Join waitlist
      </button>
    </form>

    <div id="waitlist-success" class="hidden mt-3 text-[13px] text-green">
      You're on the list. We'll notify you when OSChief is ready.
    </div>
    <div id="waitlist-error" class="hidden mt-3 text-[13px] text-red-400">
      Something went wrong. Please try again.
    </div>

    <p class="mt-5 text-[11px] text-muted-foreground">
      macOS only &middot; Apple Silicon (M1+) &middot; No spam, ever
    </p>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2" style="animation: float 2.5s ease-in-out infinite;">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-muted-foreground"><path d="M7 13l5 5 5-5"/><path d="M7 6l5 5 5-5"/></svg>
  </div>
</section>

<script is:inline>
  const form = document.getElementById('waitlist-form');
  const success = document.getElementById('waitlist-success');
  const error = document.getElementById('waitlist-error');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    success?.classList.add('hidden');
    error?.classList.add('hidden');
    const email = new FormData(form).get('email');
    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      if (res.ok) { success?.classList.remove('hidden'); form.reset(); }
      else {
        const data = await res.json().catch(() => ({}));
        if (data.error === 'already_subscribed') {
          success?.classList.remove('hidden');
          success.textContent = "You're already on the list!";
        } else { error?.classList.remove('hidden'); }
      }
    } catch { error?.classList.remove('hidden'); }
  });
</script>
