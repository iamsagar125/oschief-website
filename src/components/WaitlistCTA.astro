<section class="py-20 md:py-32 px-4 md:px-6 text-center gradient-section" data-animate="fade-up">
  <div class="max-w-[520px] mx-auto">
    <h2 class="font-display text-[28px] md:text-[44px] leading-[1.08] text-foreground mb-4">
      Stop letting promises slip
    </h2>
    <p class="text-[14px] md:text-[15px] text-muted-foreground mb-8">
      OSChief is launching soon. Be the first to try it.
    </p>

    <form id="waitlist-form-bottom" class="flex flex-col sm:flex-row gap-3 max-w-[440px] mx-auto">
      <input
        type="email"
        name="email"
        required
        placeholder="you@company.com"
        class="flex-1 h-14 px-4 text-[16px] bg-card border-2 border-border rounded-md text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors"
      />
      <button
        type="submit"
        class="h-14 px-7 text-[15px] font-semibold bg-primary text-primary-foreground rounded-md hover:opacity-90 transition-opacity whitespace-nowrap sm:w-auto w-full"
      >
        Join waitlist
      </button>
    </form>

    <div id="waitlist-success-bottom" class="hidden mt-3 text-[13px] text-green">
      You're on the list. We'll notify you when OSChief is ready.
    </div>
    <div id="waitlist-error-bottom" class="hidden mt-3 text-[13px] text-red-400">
      Something went wrong. Please try again.
    </div>
  </div>
</section>

<script is:inline>
  const form2 = document.getElementById('waitlist-form-bottom');
  const success2 = document.getElementById('waitlist-success-bottom');
  const error2 = document.getElementById('waitlist-error-bottom');
  form2?.addEventListener('submit', async (e) => {
    e.preventDefault();
    success2?.classList.add('hidden');
    error2?.classList.add('hidden');
    const email = new FormData(form2).get('email');
    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      if (res.ok) { success2?.classList.remove('hidden'); form2.reset(); }
      else {
        const data = await res.json().catch(() => ({}));
        if (data.error === 'already_subscribed') {
          success2?.classList.remove('hidden');
          success2.textContent = "You're already on the list!";
        } else { error2?.classList.remove('hidden'); }
      }
    } catch { error2?.classList.remove('hidden'); }
  });
</script>
