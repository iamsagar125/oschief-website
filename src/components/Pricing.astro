<section id="pricing" class="py-20 md:py-28 px-4 md:px-6" data-animate="fade-up">
  <div class="max-w-[800px] mx-auto text-center">
    <p class="text-[11px] font-medium uppercase tracking-[0.15em] text-primary mb-4">Pricing</p>
    <h2 class="font-display text-[28px] md:text-[44px] leading-[1.08] text-foreground mb-4">
      Track every commitment. Free.
    </h2>
    <p class="text-[14px] md:text-[15px] text-muted-foreground max-w-[460px] mx-auto mb-10 md:mb-12">
      The core product runs fully on-device with local AI at zero cost. Pro adds convenience.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-5 text-left">
      <!-- Free -->
      <div class="border border-border rounded-md p-6 md:p-7 bg-card/30">
        <p class="text-[11px] font-medium uppercase tracking-widest text-muted-foreground mb-3">Free</p>
        <div class="flex items-baseline gap-1 mb-2">
          <span class="text-[40px] md:text-[44px] font-semibold text-foreground leading-none">$0</span>
          <span class="text-[14px] text-muted-foreground">forever</span>
        </div>
        <p class="text-[13px] text-muted-foreground mb-5 md:mb-6">Local AI included. No API keys.</p>
        <ul class="space-y-2.5">
          {['On-device recording & transcription', 'Commitment tracking with risk scoring', 'People graph & decision registry', 'Obsidian, Jira, Slack export', 'Open source (MIT)'].map(item => (
            <li class="flex items-start gap-2 text-[13px] text-muted-foreground">
              <svg class="w-3.5 h-3.5 text-green mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Pro -->
      <div class="border border-primary/50 rounded-md p-6 md:p-7 bg-card/30 relative">
        <div class="absolute -top-3 left-6 md:left-7 px-3 py-0.5 bg-primary text-primary-foreground text-[10px] font-semibold rounded-full uppercase tracking-wider">
          Support development
        </div>
        <p class="text-[11px] font-medium uppercase tracking-widest text-muted-foreground mb-3">Pro</p>
        <div class="flex items-baseline gap-1 mb-2">
          <span class="text-[40px] md:text-[44px] font-semibold text-foreground leading-none">$5</span>
          <span class="text-[14px] text-muted-foreground">/month</span>
        </div>
        <p class="text-[13px] text-muted-foreground mb-5 md:mb-6">Frequent updates + cloud sync.</p>
        <ul class="space-y-2.5">
          {['Everything in Free', 'iCloud sync across Macs', 'Priority access to new features', 'Automatic updates via App Store', 'Priority support', 'Fund open-source development'].map(item => (
            <li class="flex items-start gap-2 text-[13px] text-muted-foreground">
              <svg class="w-3.5 h-3.5 text-green mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
