---
const links = [
  { label: 'Features', href: '#features' },
  { label: 'Pricing', href: '#pricing' },
  { label: 'Privacy', href: '#privacy' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 border-b border-border bg-background/80 backdrop-blur-sm">
  <div class="max-w-content mx-auto px-6 h-14 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5">
      <img src="/images/app-icon.png" alt="OSChief" width="28" height="28" class="rounded-md" />
      <span class="font-sans font-semibold text-[15px] text-foreground">OSChief</span>
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-6">
      {links.map(link => (
        <a href={link.href} class="text-[13px] font-medium text-muted-foreground hover:text-foreground transition-colors">
          {link.label}
        </a>
      ))}
      <a
        href="https://github.com/iamsagar125/oschief.ai"
        target="_blank"
        rel="noopener"
        class="text-[13px] font-medium text-muted-foreground hover:text-foreground transition-colors flex items-center gap-1"
      >
        GitHub
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
      </a>
      <!-- Dark mode toggle -->
      <button
        id="theme-toggle"
        class="p-1.5 rounded-sm text-muted-foreground hover:text-foreground transition-colors"
        aria-label="Toggle dark mode"
      >
        <!-- Sun (shown in dark mode) -->
        <svg class="hidden dark:block w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <!-- Moon (shown in light mode) -->
        <svg class="block dark:hidden w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
    </div>

    <!-- Mobile hamburger -->
    <button id="mobile-menu-btn" class="md:hidden p-1.5 text-muted-foreground" aria-label="Menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-background px-6 py-4">
    <div class="flex flex-col gap-3">
      {links.map(link => (
        <a href={link.href} class="text-[13px] font-medium text-muted-foreground hover:text-foreground">{link.label}</a>
      ))}
      <a href="https://github.com/iamsagar125/oschief.ai" target="_blank" rel="noopener" class="text-[13px] font-medium text-muted-foreground hover:text-foreground">GitHub</a>
      <button id="theme-toggle-mobile" class="text-left text-[13px] font-medium text-muted-foreground hover:text-foreground">Toggle dark mode</button>
    </div>
  </div>
</nav>

<script is:inline>
  // Theme toggle
  function toggleTheme() {
    const html = document.documentElement;
    const isDark = html.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  }
  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
  document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);

  // Mobile menu
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
